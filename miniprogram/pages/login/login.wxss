.page {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 60rpx;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.logo-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
}

.logo-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.form-section {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  flex: 1;
  padding: 60rpx 40rpx;
}

.input-group {
  margin-bottom: 60rpx;
}

.input-item {
  display: flex;
  align-items: center;
  background: #fafafa;
  border-radius: 12rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
}

.input-item:last-child {
  margin-bottom: 0;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.input-field {
  flex: 1;
  font-size: 30rpx;
}

.action-group {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
  border-radius: 48rpx;
  margin-bottom: 30rpx;
}

.submit-btn.disabled {
  background: #ddd;
}

.submit-btn .btn-text {
  font-size: 34rpx;
  color: #fff;
  font-weight: bold;
}

.submit-btn.disabled .btn-text {
  color: #999;
}

.register-link {
  font-size: 28rpx;
  color: #666;
}

.register-link .link-text {
  color: #ff6b6b;
  margin-left: 8rpx;
}

.demo-section {
  background: #fff;
  margin: 0 30rpx 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
}

.demo-header {
  margin-bottom: 20rpx;
}

.demo-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.demo-content {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 24rpx;
}

.demo-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.demo-item:last-child {
  margin-bottom: 0;
}

.demo-label {
  font-size: 26rpx;
  color: #999;
}

.demo-value {
  font-size: 28rpx;
  color: #ff6b6b;
  font-weight: bold;
  padding: 4rpx 16rpx;
  background: rgba(255, 107, 107, 0.1);
  border-radius: 8rpx;
}

.demo-tip {
  margin-top: 16rpx;
  text-align: center;
}

.demo-tip text {
  font-size: 22rpx;
  color: #999;
}

.logged-section {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100rpx;
}

.logged-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #fff;
  margin-bottom: 30rpx;
}

.logged-text {
  font-size: 36rpx;
  color: #333;
  margin-bottom: 60rpx;
}

.logged-actions {
  display: flex;
  flex-direction: column;
  width: 100%;
  padding: 0 60rpx;
}

.logged-btn {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
  border-radius: 48rpx;
  margin-bottom: 24rpx;
}

.logged-btn.outline {
  background: #fff;
  border: 2rpx solid #ff6b6b;
}

.logged-btn .btn-text {
  font-size: 32rpx;
  color: #fff;
}

.logged-btn.outline .btn-text {
  color: #ff6b6b;
}
