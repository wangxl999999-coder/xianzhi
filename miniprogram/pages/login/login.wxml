<view class="page">
  <view class="logo-section">
    <view class="logo-icon">
      <text class="logo-text">闲置</text>
    </view>
    <text class="logo-desc">本地社区闲置交易平台</text>
  </view>

  <view class="form-section">
    <view class="input-group">
      <view class="input-item">
        <text class="input-icon">👤</text>
        <input class="input-field" placeholder="请输入用户名" value="{{username}}" bindinput="onUsernameInput" />
      </view>
      <view class="input-item">
        <text class="input-icon">🔒</text>
        <input class="input-field" placeholder="请输入密码" password="true" value="{{password}}" bindinput="onPasswordInput" />
      </view>
    </view>

    <view class="action-group">
      <view class="submit-btn {{canLogin ? '' : 'disabled'}}" bindtap="handleLogin">
        <text class="btn-text">登录</text>
      </view>
      <view class="register-link" bindtap="goToRegister">
        <text>还没有账号？</text>
        <text class="link-text">立即注册</text>
      </view>
    </view>
  </view>

  <view class="logged-section" wx:if="{{isLoggedIn}}">
    <view class="logged-icon">✓</view>
    <text class="logged-text">您已登录</text>
    <view class="logged-actions">
      <view class="logged-btn" bindtap="goToHome">
        <text class="btn-text">返回首页</text>
      </view>
      <view class="logged-btn outline" bindtap="handleLogout">
        <text class="btn-text">退出登录</text>
      </view>
    </view>
  </view>
</view>
