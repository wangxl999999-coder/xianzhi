.page {
  background: #f5f5f5;
  padding-bottom: 140rpx;
}

.form-section {
  background: #fff;
  padding: 20rpx 30rpx;
}

.form-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.required {
  color: #ff6b6b;
  margin-right: 6rpx;
}

.form-label .tip {
  margin-left: auto;
  font-size: 24rpx;
  color: #999;
}

.upload-area {
  display: flex;
  flex-wrap: wrap;
  margin-left: -12rpx;
}

.upload-item {
  width: 200rpx;
  height: 200rpx;
  margin-left: 12rpx;
  margin-bottom: 12rpx;
  position: relative;
  border-radius: 8rpx;
  overflow: hidden;
}

.upload-image {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  margin-left: 12rpx;
  margin-bottom: 12rpx;
  background: #fafafa;
  border: 2rpx dashed #ddd;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 60rpx;
  color: #ccc;
  line-height: 1;
}

.upload-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.form-input-wrapper {
  display: flex;
  align-items: center;
  background: #fafafa;
  border-radius: 8rpx;
  padding: 20rpx;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
}

.char-count {
  font-size: 22rpx;
  color: #ccc;
}

.form-textarea-wrapper {
  background: #fafafa;
  border-radius: 8rpx;
  padding: 20rpx;
  position: relative;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
}

.form-textarea-wrapper .char-count {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
}

.price-inputs {
  display: flex;
  align-items: center;
}

.price-input-wrapper {
  display: flex;
  align-items: center;
  background: #fafafa;
  border-radius: 8rpx;
  padding: 20rpx;
}

.price-input-wrapper.original {
  flex: 1;
}

.price-prefix {
  font-size: 28rpx;
  color: #ff6b6b;
  margin-right: 8rpx;
}

.price-input-wrapper.original .price-prefix {
  color: #999;
  font-size: 24rpx;
}

.price-input {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b6b;
  min-width: 120rpx;
}

.price-input-wrapper.original .price-input {
  font-size: 28rpx;
  font-weight: normal;
  color: #333;
  min-width: auto;
}

.price-divider {
  font-size: 32rpx;
  color: #ccc;
  margin: 0 30rpx;
}

.condition-options {
  display: flex;
  flex-wrap: wrap;
  margin-left: -16rpx;
}

.condition-option {
  padding: 16rpx 36rpx;
  margin-left: 16rpx;
  margin-bottom: 16rpx;
  background: #fafafa;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.condition-option.active {
  background: rgba(255, 107, 107, 0.1);
  color: #ff6b6b;
}

.form-picker {
  display: flex;
  align-items: center;
  background: #fafafa;
  border-radius: 8rpx;
  padding: 20rpx;
}

.form-picker .placeholder {
  color: #999;
}

.picker-arrow {
  margin-left: auto;
  font-size: 28rpx;
  color: #ccc;
}

.pickup-options {
  display: flex;
}

.pickup-option {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  margin-right: 20rpx;
  background: #fafafa;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.pickup-option:last-child {
  margin-right: 0;
}

.pickup-option.active {
  background: rgba(255, 107, 107, 0.1);
  color: #ff6b6b;
}

.location-picker {
  display: flex;
  align-items: center;
  background: #fafafa;
  border-radius: 8rpx;
  padding: 20rpx;
}

.location-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.location-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.location-info .placeholder {
  color: #999;
}

.location-tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.contact-inputs {
  display: flex;
  flex-direction: column;
}

.contact-input-wrapper {
  display: flex;
  align-items: center;
  background: #fafafa;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.contact-input-wrapper:last-child {
  margin-bottom: 0;
}

.contact-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.contact-input {
  flex: 1;
  font-size: 28rpx;
}

.contact-tip {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 107, 107, 0.05);
  border-radius: 8rpx;
}

.contact-tip text {
  font-size: 24rpx;
  color: #ff6b6b;
}

.category-picker-popup .popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.category-picker-popup .popup-content {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 101;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.category-picker-popup .popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-picker-popup .popup-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.category-picker-popup .popup-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.category-picker-popup .popup-scroll {
  flex: 1;
  overflow-y: auto;
  max-height: 50vh;
}

.category-list {
  padding: 10rpx 0;
}

.category-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.category-item:last-child {
  border-bottom: none;
}

.category-name {
  font-size: 28rpx;
  color: #333;
}

.category-check {
  font-size: 32rpx;
  color: #ff6b6b;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
  border-radius: 44rpx;
}

.submit-btn.disabled {
  background: #ddd;
}

.submit-btn .btn-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.submit-btn.disabled .btn-text {
  color: #999;
}
