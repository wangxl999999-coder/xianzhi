<view class="page">
  <view class="header-section">
    <view class="user-info" wx:if="{{isLoggedIn}}" bindtap="goToUserCenter">
      <image class="user-avatar" src="{{userInfo.avatar || defaultAvatar}}" mode="aspectFill"></image>
      <view class="user-detail">
        <text class="user-name">{{userInfo.nickname || userInfo.username}}</text>
        <view class="user-stats">
          <text class="stat-item">{{userInfo.itemsCount || 0}} 件发布</text>
          <text class="stat-item">{{userInfo.favoritesCount || 0}} 件收藏</text>
        </view>
      </view>
      <text class="user-arrow">></text>
    </view>

    <view class="login-prompt" wx:else bindtap="goToLogin">
      <view class="login-avatar">
        <text class="login-icon">👤</text>
      </view>
      <view class="login-text">
        <text class="login-title">登录/注册</text>
        <text class="login-desc">登录后即可发布闲置品</text>
      </view>
      <text class="login-arrow">></text>
    </view>

    <view class="quick-actions" wx:if="{{isLoggedIn}}">
      <view class="quick-action" bindtap="goToMyItems">
        <text class="action-icon">📦</text>
        <text class="action-text">我的发布</text>
        <text class="action-count" wx:if="{{userInfo.itemsCount > 0}}">{{userInfo.itemsCount}}</text>
      </view>
      <view class="quick-action" bindtap="goToMyFavorites">
        <text class="action-icon">❤</text>
        <text class="action-text">我的收藏</text>
        <text class="action-count" wx:if="{{userInfo.favoritesCount > 0}}">{{userInfo.favoritesCount}}</text>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-group">
      <view class="menu-item" bindtap="goToPublish" wx:if="{{isLoggedIn}}">
        <text class="menu-icon">✏️</text>
        <text class="menu-text">发布闲置</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToMyItems">
        <text class="menu-icon">📋</text>
        <text class="menu-text">我的发布</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goToMyFavorites">
        <text class="menu-icon">❤</text>
        <text class="menu-text">我的收藏</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="goToAbout">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <view class="menu-group" wx:if="{{isLoggedIn}}">
      <view class="menu-item logout-item" bindtap="handleLogout">
        <text class="menu-icon">🚪</text>
        <text class="menu-text">退出登录</text>
      </view>
    </view>
  </view>

  <view class="version-info">
    <text>闲置社区 v1.0.0</text>
  </view>
</view>
