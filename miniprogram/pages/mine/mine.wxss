.page {
  background: #f5f5f5;
  min-height: 100vh;
}

.header-section {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
  padding: 40rpx 30rpx 30rpx;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.user-detail {
  flex: 1;
  margin-left: 24rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.user-stats {
  display: flex;
}

.stat-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-right: 30rpx;
}

.user-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
}

.login-prompt {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.login-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-icon {
  font-size: 56rpx;
}

.login-text {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.login-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.login-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
}

.quick-actions {
  display: flex;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 24rpx 0;
}

.quick-action {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.quick-action:first-child {
  border-right: 1rpx solid rgba(255, 255, 255, 0.2);
}

.action-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 26rpx;
  color: #fff;
}

.action-count {
  position: absolute;
  top: 0;
  right: 30rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #ff4d4f;
  border-radius: 16rpx;
  font-size: 20rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.menu-section {
  margin-top: 20rpx;
}

.menu-group {
  background: #fff;
  margin-bottom: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.logout-item {
  justify-content: center;
}

.logout-item .menu-text {
  flex: none;
  color: #ff6b6b;
}

.version-info {
  text-align: center;
  padding: 60rpx 0;
}

.version-info text {
  font-size: 24rpx;
  color: #ccc;
}
