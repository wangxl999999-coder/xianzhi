.page {
  background: #f5f5f5;
  min-height: 100vh;
}

.header-section {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 80rpx;
}

.logo-wrapper {
  margin-bottom: 24rpx;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-text {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
}

.app-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.app-version {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.info-section {
  margin-top: -40rpx;
  padding: 0 30rpx 40rpx;
}

.info-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.info-value {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.info-value:last-child {
  margin-bottom: 0;
}

.feature-list {
  display: flex;
  flex-wrap: wrap;
}

.feature-item {
  width: 50%;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.feature-dot {
  width: 12rpx;
  height: 12rpx;
  background: #ff6b6b;
  border-radius: 50%;
  margin-right: 16rpx;
}

.feature-text {
  font-size: 26rpx;
  color: #666;
}

.contact-list {
  margin-top: 10rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.contact-item:last-child {
  border-bottom: none;
}

.contact-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.contact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.contact-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.contact-value {
  font-size: 28rpx;
  color: #333;
}

.copy-btn {
  padding: 10rpx 24rpx;
  background: rgba(255, 107, 107, 0.1);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #ff6b6b;
}

.contact-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.footer-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 60rpx;
}

.footer-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.footer-copyright {
  font-size: 24rpx;
  color: #ccc;
}
