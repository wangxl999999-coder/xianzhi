.page {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
  min-height: 100vh;
}

.header-section {
  padding: 60rpx 40rpx 40rpx;
}

.header-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.header-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.form-section {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  min-height: calc(100vh - 200rpx);
  padding: 40rpx;
}

.input-group {
  margin-bottom: 30rpx;
}

.input-item {
  margin-bottom: 24rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.input-field {
  width: 100%;
  height: 96rpx;
  background: #fafafa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.tip-section {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.tip-icon {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #ddd;
  margin-right: 16rpx;
}

.tip-icon.valid {
  background: #52c41a;
  border-color: #52c41a;
  color: #fff;
}

.tip-text {
  font-size: 26rpx;
  color: #999;
}

.action-group {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
  border-radius: 48rpx;
  margin-bottom: 30rpx;
}

.submit-btn.disabled {
  background: #ddd;
}

.submit-btn .btn-text {
  font-size: 34rpx;
  color: #fff;
  font-weight: bold;
}

.submit-btn.disabled .btn-text {
  color: #999;
}

.login-link {
  font-size: 28rpx;
  color: #666;
}

.login-link .link-text {
  color: #ff6b6b;
  margin-left: 8rpx;
}
