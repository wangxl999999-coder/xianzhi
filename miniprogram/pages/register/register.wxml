<view class="page">
  <view class="header-section">
    <text class="header-title">注册账号</text>
    <text class="header-desc">加入闲置社区，让闲置物品流动起来</text>
  </view>

  <view class="form-section">
    <view class="input-group">
      <view class="input-item">
        <text class="input-label">用户名</text>
        <input class="input-field" placeholder="请输入用户名（2-50个字符）" value="{{username}}" bindinput="onUsernameInput" maxlength="50" />
      </view>
      <view class="input-item">
        <text class="input-label">昵称</text>
        <input class="input-field" placeholder="请输入昵称（选填）" value="{{nickname}}" bindinput="onNicknameInput" maxlength="50" />
      </view>
      <view class="input-item">
        <text class="input-label">密码</text>
        <input class="input-field" placeholder="请输入密码（6-20个字符）" password="true" value="{{password}}" bindinput="onPasswordInput" maxlength="20" />
      </view>
      <view class="input-item">
        <text class="input-label">确认密码</text>
        <input class="input-field" placeholder="请再次输入密码" password="true" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" maxlength="20" />
      </view>
      <view class="input-item">
        <text class="input-label">手机号</text>
        <input class="input-field" type="number" placeholder="请输入手机号（选填）" value="{{phone}}" bindinput="onPhoneInput" maxlength="11" />
      </view>
      <view class="input-item">
        <text class="input-label">微信号</text>
        <input class="input-field" placeholder="请输入微信号（选填）" value="{{wechat}}" bindinput="onWechatInput" />
      </view>
    </view>

    <view class="tip-section">
      <view class="tip-item">
        <text class="tip-icon {{passwordStrength >= 1 ? 'valid' : ''}}">✓</text>
        <text class="tip-text">密码长度6-20个字符</text>
      </view>
      <view class="tip-item">
        <text class="tip-icon {{passwordsMatch ? 'valid' : ''}}">✓</text>
        <text class="tip-text">两次密码输入一致</text>
      </view>
    </view>

    <view class="action-group">
      <view class="submit-btn {{canRegister ? '' : 'disabled'}}" bindtap="handleRegister">
        <text class="btn-text">注册</text>
      </view>
      <view class="login-link" bindtap="goToLogin">
        <text>已有账号？</text>
        <text class="link-text">立即登录</text>
      </view>
    </view>
  </view>
</view>
